{
  "$schema": "https://charm.land/crush.json",
  "mcp": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "$(echo Bearer $GITHUB_PAT)" }
    },
    "sequentialthinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  },
  "lsp": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "oxlint": { "command": "oxc_language_server" },
    "csharp": { "command": "csharp-ls", "args": [] }
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "grep",
      "ls",
      "mcp_sequentialthinking_sequential_thinking"
    ]
  }
}
